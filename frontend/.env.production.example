# Production Environment Variables for Vercel Deployment
# Set these in Vercel Dashboard > Project > Settings > Environment Variables

# Backend API URL - REQUIRED
# Set to your production backend URL (e.g. HuggingFace Spaces, Railway, or self-hosted)
NEXT_PUBLIC_API_URL=https://your-backend-url.example.com

# App URL - Set automatically by Vercel, but can override
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# WebSocket URL - Set to wss:// for production
# NEXT_PUBLIC_WEBSOCKET_URL=wss://your-backend-url.example.com
