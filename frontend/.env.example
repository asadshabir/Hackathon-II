# =============================================================================
# Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# Set these in Vercel Dashboard > Project > Settings > Environment Variables
# =============================================================================

# Backend API Base URL (REQUIRED)
# Local development: http://localhost:8000
# Docker Compose: http://localhost:8000
# Production: https://your-backend-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# App URL (used for auth redirects and CORS)
# Local development: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WebSocket URL (optional - derived from API_URL if not set)
# Local development: ws://localhost:8000
# Production: wss://your-backend-domain.com
# NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8000

# =============================================================================
# Optional: Analytics & Monitoring
# =============================================================================

# Vercel Analytics (auto-configured on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Sentry Error Tracking
# NEXT_PUBLIC_SENTRY_DSN=
